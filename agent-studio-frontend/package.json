{
  "name": "agent-studio-frontend",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "openui:spec": "openui generate src/openui/library.jsx --json-schema --out src/openui/generated/component-spec.json",
    "openui:prompts": "node scripts/generate-openui-prompt.mjs",
